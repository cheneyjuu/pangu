<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pangu.infrastructure.persistence.mapper.VotingSubjectMapper">

    <resultMap id="VotingSubjectRowMap"
               type="com.pangu.infrastructure.persistence.entity.VotingSubjectRow">
        <id property="subjectId" column="subject_id"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="title" column="title"/>
        <result property="subjectType" column="subject_type"/>
        <result property="scope" column="scope"/>
        <result property="scopeReferenceId" column="scope_reference_id"/>
        <result property="status" column="status"/>
        <result property="publishAt" column="publish_at"/>
        <result property="voteStartAt" column="vote_start_at"/>
        <result property="voteEndAt" column="vote_end_at"/>
        <result property="settledAt" column="settled_at"/>
        <result property="partyRatioFloor" column="party_ratio_floor"/>
        <result property="maxWinners" column="max_winners"/>
        <result property="version" column="version"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="all_columns">
        subject_id, tenant_id, title, subject_type, scope, scope_reference_id,
        status, publish_at, vote_start_at, vote_end_at, settled_at,
        party_ratio_floor, max_winners, version, create_time
    </sql>

    <select id="selectById" resultMap="VotingSubjectRowMap">
        SELECT <include refid="all_columns"/>
        FROM t_voting_subject
        WHERE subject_id = #{subjectId}
    </select>

    <select id="selectByIdForUpdate" resultMap="VotingSubjectRowMap">
        SELECT <include refid="all_columns"/>
        FROM t_voting_subject
        WHERE subject_id = #{subjectId}
        FOR UPDATE
    </select>

    <update id="updatePartyRatioFloor">
        UPDATE t_voting_subject
        SET party_ratio_floor = #{partyRatioFloor},
            version           = version + 1
        WHERE subject_id = #{subjectId}
          AND version = #{expectedVersion}
    </update>

    <!-- newStatus=5 (SETTLED) 时同步落 settled_at；其他状态不动 settled_at -->
    <update id="updateStatus">
        UPDATE t_voting_subject
        SET status      = #{newStatus},
            settled_at  = CASE WHEN #{newStatus} = 5 THEN CURRENT_TIMESTAMP ELSE settled_at END,
            version     = version + 1
        WHERE subject_id = #{subjectId}
          AND version = #{expectedVersion}
    </update>

    <select id="selectExpiredVoting" resultMap="VotingSubjectRowMap">
        SELECT <include refid="all_columns"/>
        FROM t_voting_subject
        WHERE status = 3
          AND vote_end_at IS NOT NULL
          AND vote_end_at &lt; #{now}
        ORDER BY vote_end_at ASC
        LIMIT #{limit}
    </select>

</mapper>
