<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pangu.infrastructure.persistence.mapper.OwnerPropertyMapper">

    <!-- 房产所有权映射 ResultMap -->
    <resultMap id="PropertyOwnershipResultMap" type="com.pangu.domain.model.asset.PropertyOwnership">
        <result property="roomId" column="room_id"/>
        <result property="opid" column="opid"/>
        <result property="isVotingRepresentative" column="is_voting_delegate" javaType="boolean"/>
        <result property="accountStatus" column="account_status"/>
    </resultMap>

    <!-- 根据 UID 与租户 ID 查询所有绑定的房产所有权关系 -->
    <select id="selectOwnershipsByUid" resultMap="PropertyOwnershipResultMap">
        SELECT
            opid,
            room_id,
            is_voting_delegate,
            account_status
        FROM c_owner_property
        WHERE uid = #{uid} AND tenant_id = #{tenantId}
    </select>

    <!-- 统计某自然人在小区内非正常的欠费房产套数 (account_status != 1 视为欠费/冻结) -->
    <select id="countUnpaidProperties" resultType="int">
        SELECT COUNT(1)
        FROM c_owner_property
        WHERE uid = #{uid} 
          AND tenant_id = #{tenantId} 
          AND account_status != 1
    </select>

    <!-- 根据 opid 查询单一绑定 -->
    <select id="selectByOpid" resultMap="PropertyOwnershipResultMap">
        SELECT
            opid,
            room_id,
            is_voting_delegate,
            account_status
        FROM c_owner_property
        WHERE opid = #{opid}
    </select>

    <!-- 管理端网格员根据楼栋管辖范围查询房产关系列表 -->
    <select id="selectOwnershipsByBuilding" resultMap="PropertyOwnershipResultMap">
        SELECT
            op.opid,
            op.room_id,
            op.is_voting_delegate,
            op.account_status
        FROM c_owner_property op
        WHERE op.tenant_id = #{tenantId}
    </select>

    <!-- ===================== M3-2 投票提交 / "我的议题" ===================== -->
    <resultMap id="VotingViewResultMap"
               type="com.pangu.infrastructure.persistence.entity.OwnerPropertyVotingViewRow">
        <id property="opid" column="opid"/>
        <result property="uid" column="uid"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="buildingId" column="building_id"/>
        <result property="buildArea" column="build_area"/>
        <result property="votingDelegate" column="is_voting_delegate"/>
        <result property="accountStatus" column="account_status"/>
    </resultMap>

    <select id="selectVotingViewByOpid" resultMap="VotingViewResultMap">
        SELECT opid, uid, tenant_id, building_id, build_area,
               is_voting_delegate, account_status
        FROM c_owner_property
        WHERE opid = #{opid}
    </select>

    <select id="selectBuildingIdsByUid" resultType="long">
        SELECT DISTINCT building_id
        FROM c_owner_property
        WHERE uid = #{uid} AND tenant_id = #{tenantId}
    </select>

    <!-- ===================== 提名候选人:按手机号检索业主 ===================== -->
    <!-- phone 作普通明文列映射(走 idx_account_phone 前缀匹配),不选 real_name(SM4 加密列) -->
    <resultMap id="OwnerLookupResultMap"
               type="com.pangu.infrastructure.persistence.entity.OwnerLookupRow">
        <id property="uid" column="uid"/>
        <result property="phone" column="phone"/>
        <result property="buildingId" column="building_id"/>
        <result property="roomId" column="room_id"/>
    </resultMap>

    <select id="searchOwnersByPhonePrefix" resultMap="OwnerLookupResultMap">
        SELECT cu.uid AS uid,
               a.phone AS phone,
               MIN(op.building_id) AS building_id,
               MIN(op.room_id) AS room_id
        FROM t_account a
        JOIN c_user cu ON cu.account_id = a.account_id
        JOIN c_owner_property op ON op.uid = cu.uid AND op.tenant_id = #{tenantId}
        WHERE a.phone LIKE CONCAT(#{phonePrefix}, '%')
        GROUP BY cu.uid, a.phone
        ORDER BY a.phone
        LIMIT 20
    </select>

</mapper>
